ANTHROPIC_API_KEY=
# Kalshi v2 trading API uses RSA-PSS request signing.
# 1. Log in to Kalshi, go to API Keys, create a new key, download the private key (.pem)
# 2. Set KALSHI_API_KEY to the access key UUID shown in the dashboard
# 3. Set KALSHI_PRIVATE_KEY_PATH to the absolute path of the .pem file
KALSHI_API_KEY=
KALSHI_PRIVATE_KEY_PATH=
POLYMARKET_API_KEY=
FRED_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=
ODDS_API_KEY=
BANKROLL=1000
EDGE_THRESHOLD=0.08
MOCK_TOOLS=false

# WARNING: Set LIVE_TRADING_ENABLED=true only when ready to place real orders
LIVE_TRADING_ENABLED=false
MAX_LIVE_BANKROLL=50.00
MAX_SINGLE_BET=10.00

# Per-tool rate limits (requests/minute). Default is 10 for all tools.
# Uncomment and adjust as needed.
# RATE_LIMIT_KALSHI=10
# RATE_LIMIT_POLYMARKET=10
# RATE_LIMIT_METACULUS=10
# RATE_LIMIT_FED_DATA=10
# RATE_LIMIT_SEARCH_NEWS=10
# RATE_LIMIT_SPORTS_DATA=10
# RATE_LIMIT_SEC_FILINGS=10
# RATE_LIMIT_MANIFOLD=10
# RATE_LIMIT_ACADEMIC_FORECASTING=10
# RATE_LIMIT_TWITTER_SENTIMENT=5
# RATE_LIMIT_POLLING_DATA=10
